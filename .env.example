# Perskill Research Pipeline — Environment Variables
# Copy this file to .env and fill in your API keys.
# Scripts auto-load .env on startup — no manual export needed.

# ─── Twitter ──────────────────────────────────────────────────────────────────
# Used by: twitter-scraper.ts, pipeline.ts
# Get from: https://twitterapi.io (free tier: 500 tweets/month)
VITE_TWITTER_API_KEY=

# ─── Firecrawl ────────────────────────────────────────────────────────────────
# Used by: firecrawl-discovery.ts, firecrawl-research.ts, pipeline.ts, deep research scripts
# Get from: https://firecrawl.dev (free tier: 500 credits/month)
VITE_FIRECRAWL_API_KEY=

# ─── Tavily ───────────────────────────────────────────────────────────────────
# Used by: tavily_search.py (NEW — LLM-optimized search engine)
# Get from: https://tavily.com (free tier: 1,000 searches/month)
# This key is used directly by the Python script, not via VITE_ prefix.
# Set as TAVILY_API_KEY here and also copy to VITE_TAVILY_API_KEY for consistency.
TAVILY_API_KEY=
VITE_TAVILY_API_KEY=

# ─── Kimi (Moonshot AI) — Board Deliberation ───────────────────────────────────
# Used by: Board deliberation generation (K2.6 model)
# Get from: https://platform.moonshot.cn (free tier: 10M tokens/month for new accounts)
VITE_KIMI_API_KEY=

# ─── MiniMax — Board Deliberation ──────────────────────────────────────────────
# Used by: Board deliberation generation (M2.7 model, fast)
# Get from: https://platform.minimax.io
VITE_MINIMAX_API_KEY=

# ─── Meta Threads ──────────────────────────────────────────────────────────────
# Used by: threads-scraper.ts, pipeline.ts
# Only works for the token owner's own Threads data.
# Requires a Meta app with threads_get_updates permission.
# LEAVE BLANK if not using Threads scraping.
VITE_META_THREADS_TOKEN=

# ─── Notes ───────────────────────────────────────────────────────────────────
# The Python scripts (tavily_search.py, free_sources.py) read these vars directly:
#   - TAVILY_API_KEY or VITE_TAVILY_API_KEY
#   - They need NO other API keys (free_sources.py uses only public APIs)
